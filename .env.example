# ==========================================
# Copy this file to `.env` and fill in the values.
# Client-side variables must be prefixed with NEXT_PUBLIC_. Validation is in src/config/env.ts.
# ===================================================================

# /** App Core */
NEXT_PUBLIC_APP_URL=http://localhost:3000

# /** API & Integrations */
API_BASE_URL=http://localhost:4000
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# /** Auth & Security */
# Generate via: `npx auth secret`
AUTH_SECRET=

# Shared secret used by `/api/revalidate` to authenticate cache-invalidation
# webhooks from NestJS. Min 16 chars. Generate via:
#   openssl rand -hex 32
# Optional in dev (the route returns 503 when unset). Required in production.
REVALIDATE_SECRET=

# /** Optional (CI/CD) */
# Set to 'true' to bypass env validation during build (e.g., Docker/CI).
# SKIP_ENV_VALIDATION=true
